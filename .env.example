# X (Twitter) API credentials — from developer.x.com
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Postgres connection string. Render injects this automatically when you
# attach a database to your web service — you usually won't set this by
# hand on Render. For local dev, leave unset to use SQLite, or point at
# a local Postgres: postgresql://user:pass@localhost:5432/giveaway_bot
DATABASE_URL=

# How often the bot loop runs, in seconds
BOT_CYCLE_SECONDS=90

# Set to "false" to disable the background bot loop (dashboard-only mode,
# useful when debugging the UI without hitting the X API)
ENABLE_SCHEDULER=true

# Optional: restrict which X user IDs can auto-start giveaways via mention.
# Comma-separated numeric IDs. Leave blank to accept commands from anyone.
# TRUSTED_HOST_USER_IDS=123456789,987654321

# Optional: protect the dashboard with HTTP Basic Auth (recommended in production).
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=change-me

# --- Entry validation (all off by default; enable for production giveaways) ---
# REQUIRE_FOLLOW_HOST=true
# REQUIRE_FOLLOW_BOT=false
# MIN_ACCOUNT_AGE_DAYS=7
# MIN_FOLLOWERS=10
# REQUIRE_ENTRY_KEYWORD=#giveaway

# --- DM queue (scheduler drains in batches to respect X rate limits) ---
# DM_BATCH_SIZE=3
# DM_INTERVAL_SECONDS=15
# DM_MAX_ATTEMPTS=5

# --- Render keep-alive cron (set on Render; scripts/cron_wake.py uses WAKE_HOST) ---
# CRON_WAKE_SECRET=generate-a-long-random-string

# --- Schema migrations ---
# RUN_ALEMBIC_ON_STARTUP=true
