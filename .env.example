# X (Twitter) API credentials — from developer.x.com
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Postgres connection string. Render injects this automatically when you
# attach a database to your web service — you usually won't set this by
# hand on Render. For local dev, leave unset to use SQLite, or point at
# a local Postgres: postgresql://user:pass@localhost:5432/giveaway_bot
DATABASE_URL=

# How often the bot loop runs, in seconds
BOT_CYCLE_SECONDS=90

# Set to "false" to disable the background bot loop (dashboard-only mode,
# useful when debugging the UI without hitting the X API)
ENABLE_SCHEDULER=true
